[*]
insert_final_newline = true

# Microsoft .NET properties
csharp_new_line_before_members_in_object_initializers = false
csharp_space_after_cast = true
csharp_preferred_modifier_order = public, private, protected, internal, new, abstract, virtual, sealed, override, static, readonly, extern, unsafe, volatile, async:suggestion
csharp_style_var_elsewhere = true:suggestion
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
dotnet_style_parentheses_in_arithmetic_binary_operators = never_if_unnecessary:none
dotnet_style_parentheses_in_other_binary_operators = never_if_unnecessary:none
dotnet_style_parentheses_in_relational_binary_operators = never_if_unnecessary:none
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion

# ReSharper properties
resharper_align_linq_query = true
resharper_align_multiline_calls_chain = true
resharper_align_multline_type_parameter_constrains = true
resharper_align_multline_type_parameter_list = true
resharper_align_tuple_components = true
resharper_braces_for_for = required
resharper_braces_for_foreach = required
resharper_braces_for_ifelse = required
resharper_braces_for_while = required
resharper_csharp_insert_final_newline = true
resharper_csharp_wrap_chained_method_calls = chop_if_long
resharper_css_insert_final_newline = true
resharper_html_insert_final_newline = true
resharper_js_insert_final_newline = true
resharper_max_attribute_length_for_same_line = 0
resharper_place_field_attribute_on_same_line = false
resharper_place_simple_anonymousmethod_on_single_line = false
resharper_protobuf_insert_final_newline = false
resharper_resx_insert_final_newline = true
resharper_vb_insert_final_newline = false
resharper_wrap_after_dot_in_method_calls = true
resharper_wrap_before_linq_expression = true
resharper_wrap_chained_method_calls = chop_if_long
resharper_xmldoc_insert_final_newline = true
resharper_xml_insert_final_newline = true

# ReSharper inspection severities
resharper_arrange_redundant_parentheses_highlighting = hint
resharper_arrange_this_qualifier_highlighting = hint
resharper_arrange_type_member_modifiers_highlighting = hint
resharper_arrange_type_modifiers_highlighting = hint
resharper_built_in_type_reference_style_for_member_access_highlighting = hint
resharper_built_in_type_reference_style_highlighting = hint
resharper_redundant_base_qualifier_highlighting = warning
resharper_suggest_var_or_type_built_in_types_highlighting = hint
resharper_suggest_var_or_type_elsewhere_highlighting = hint
resharper_suggest_var_or_type_simple_types_highlighting = hint

[*.cs]
# CA1303: Do not pass literals as localized parameters
dotnet_diagnostic.ca1303.severity = none

# CA2007: Consider calling ConfigureAwait on the awaited task
# Justification: We don't have a synchronization context in console hosted .NET 5 app
dotnet_diagnostic.ca2007.severity = none

# CS8618 Non-nullable property 'XYZ' is uninitialized. Consider declaring the property as nullable.
# Justification: We have a lot of setters for model binding & DB access that are not called directly, but are still required even for properties that end up not being null due to validation
dotnet_diagnostic.cs8618.severity = none

# CA1032 Implement standard exception constructors
# Justification: For the application code, we do want to restrict the exception constructors sometimes.
dotnet_diagnostic.ca1032.severity = none

# CS1591 Missing XML comment for publicly available ...
# Justification: We mostly want XML documentation for DTOs & Swagger, not necessarilly _all_ public members
dotnet_diagnostic.cs1591.severity = none

# CA1062: Validate arguments of public methods
# Justification: This is adding a lot of noise and unnecessary null checks
dotnet_diagnostic.ca1062.severity = none

# CA1861: Avoid constant arrays as arguments
# Justification: This mostly happens in migrations that are autogenerated
dotnet_diagnostic.ca1861.severity = none

# CA2208: Instantiate argument exceptions correctly
# Justification: We do have a few instances in the agent where it makes sense to throw an argument exception with a different parameter name
dotnet_diagnostic.ca2208.severity = none

[*.proto]
indent_style = tab
indent_size = tab
tab_width = 4

[*.{asax,ascx,aspx,axaml,cs,cshtml,css,htm,html,js,jsx,master,paml,razor,skin,ts,tsx,vb,xaml,xamlx,xoml}]
indent_style = space
indent_size = 4
tab_width = 4

[*.{appxmanifest,axml,build,config,csproj,dbml,discomap,dtd,json,jsproj,lsproj,njsproj,nuspec,proj,props,resjson,resw,resx,StyleCop,targets,tasks,vbproj,xml,xsd}]
indent_style = space
indent_size = 2
tab_width = 2
